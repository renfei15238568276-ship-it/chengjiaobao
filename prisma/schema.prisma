// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Existing Tables (matching Supabase) ============

model Organization {
  id        Int      @id @default(autoincrement())
  name      String   @map("name")
  
  @@map("organization")
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  phone        String?
  username     String?
  passwordHash String    @map("password_hash")
  displayName  String?   @map("display_name")
  role         String    @default("user")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @map("updated_at")
  
  @@map("users")
}

model Customer {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  company         String   @default("")
  contactHandle   String   @default("") @map("contact_handle")
  source          String   @default("")
  stage           String   @default("新线索")
  owner           String   @default("")
  nextFollowUp    String   @default("") @map("next_follow_up")
  probability     Int      @default(0)
  estimatedAmount String   @default("") @map("estimated_amount")
  tags            Json?
  note            String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")
  
  @@map("customers")
}

model FollowUp {
  id          String   @id @default(uuid())
  customerId   String   @map("customer_id")
  userId      String   @map("user_id")
  type        String   @default("跟进")
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("follow_ups")
}

model AIHistory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  customerId String?  @map("customer_id")
  type       String   @default("话术生成")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@map("ai_histories")
}

model Subscription {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  planCode    String    @map("plan_code")
  planName    String    @map("plan_name")
  status      String    @default("pending")
  startsAt    DateTime? @map("starts_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")
  
  @@map("subscriptions")
}

model PlanDefinition {
  id           String  @id @default(uuid())
  planCode     String  @map("plan_code") @unique
  planName     String  @map("plan_name")
  price        Float   @default(0)
  durationDays Int     @default(30) @map("duration_days")
  isTeam       Boolean @default(false) @map("is_team")
  status       String  @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  
  @@map("plan_definitions")
}

model PaymentApplication {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  name          String
  phone         String
  wechat        String   @default("")
  planCode      String   @map("plan_code")
  payMethod     String   @map("pay_method")
  amount        String
  paidAt        String   @map("paid_at")
  screenshotUrl String?  @map("screenshot_url")
  note          String   @default("")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  
  @@map("payment_applications")
}

model MembershipLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  subscriptionId String?  @map("subscription_id")
  operatorId     String?  @map("operator_id")
  action         String
  note           String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  
  @@map("membership_logs")
}
